--------------------MAJORITY ELEMENT LC - 169---------------------
USING SORTING - TC - O(nlogn)

class Solution {
public:
    int majorityElement(vector<int>& nums) {

int n = nums.size();
sort (nums.begin (), nums.end());
return nums[n/2];
    }
};

